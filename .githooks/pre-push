#!/usr/bin/env bash
# MOC-138 Tier 3: 本地 push 门禁 —— 镜像 .github/workflows/ci.yml 的
# rust-fast-check 那一层,让「本地绿 ⇒ CI 快车道绿」语义一致,push 前
# 5~120s 内挡住 fmt / 编译 / 单测 失败,不用等 CI 来回。
#
# 注: 故意不含 CI rust-fast-check 的第 4 步 `xtask gen-fixtures` 反向 diff
# —— 那步 `--release` 编译太重会拖慢每次 push,且只在改 registry fixtures
# 的低频场景才相关。改 fixtures 的 PR 仍以 CI 为准(本门禁是 CI 的快速子集,
# 绿 ⇒ CI 前 3 步绿,但不替代 fixture-drift 检查)。
#
# 安装: scripts/install-hooks.sh   (= git config core.hooksPath .githooks)
# 卸载: git config --unset core.hooksPath
# 绕过: git push --no-verify        (临时用;CI 仍会拦,别养成习惯)
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "=== MOC-138 pre-push 门禁(镜像 ci.yml rust-fast-check)==="

# cargo 不在 PATH(部分 GUI git 客户端不继承 shell PATH)→ 放行,交给 CI 兜底,不误拦
if ! command -v cargo >/dev/null 2>&1; then
  echo "⚠️ 未找到 cargo,跳过本地编译门禁(CI 仍会跑)"
  exit 0
fi

# 1/3 fmt(对齐 ci.yml: cargo fmt --all -- --check)
echo "[1/3] cargo fmt --all -- --check"
if ! cargo fmt --all -- --check; then
  echo "❌ fmt 未过 —— 跑 'cargo fmt --all' 修复后重新 push"
  exit 1
fi

# 2/3 workspace check(排除 src-tauri,跟 ci.yml fast 车道一致,免装 webkit2gtk)
echo "[2/3] cargo check --workspace --all-targets --exclude codex-app-transfer"
cargo check --workspace --all-targets --exclude codex-app-transfer

# 3/3 workspace test(#[ignore] 的 CF 网络测试默认不跑 → hook 不触网)
echo "[3/3] cargo test --workspace --no-fail-fast --exclude codex-app-transfer"
cargo test --workspace --no-fail-fast --exclude codex-app-transfer

BRANCH=$(git rev-parse --abbrev-ref HEAD)

# advisory: 当前分支落后 origin/main 提醒(不阻塞)。
# squash-merge 被分支保护 BLOCK(branch not up to date)是 merge-time 关注点,
# 且 main 可能在最后一次 push 后才推进 —— hook 无法保证 merge 时一定 up-to-date,
# 故只预警不拦,避免反复拦 WIP push。
if [[ "$BRANCH" != "main" ]]; then
  # 用 fetch 必写的 FETCH_HEAD,不依赖 refs/remotes/origin/main 存在 —— 单分支
  # clone / 改过 remote.origin.fetch 时 `git rev-parse origin/main` 会 fatal,
  # 在 set -e 下会把「只警告」误升级成「拦 push」。整段确保只 advisory、永不阻塞。
  if git fetch origin main --quiet 2>/dev/null && MAIN_SHA=$(git rev-parse --verify FETCH_HEAD 2>/dev/null); then
    if ! git merge-base --is-ancestor "$MAIN_SHA" HEAD 2>/dev/null; then
      BEHIND=$(git rev-list --count "HEAD..$MAIN_SHA" 2>/dev/null || echo "?")
      echo "⚠️ 当前分支 $BRANCH 落后 origin/main $BEHIND commits"
      echo "   merge 前同步: git rebase origin/main  (或 gh pr update-branch)"
      echo "   否则 squash-merge 会被分支保护 BLOCK(branch not up to date)"
    fi
  else
    echo "⚠️ fetch origin/main 失败(离线?),跳过分支同步检查"
  fi
fi

# Tier 4: codex-app-transfer_test 独立 clone 漂移(仅主仓 main push 时,advisory 不阻塞)
if [[ "$BRANCH" == "main" ]] && [[ -x scripts/check-test-repo-drift.sh ]]; then
  scripts/check-test-repo-drift.sh || true
fi

echo "✅ pre-push 门禁全部通过"
