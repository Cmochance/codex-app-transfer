# Virtual environments
.venv/

# Python cache / artifacts
__pycache__/
*.pyc
.pytest_cache/
.ruff_cache/

# Python v1.4 残留 (v2 全栈 Rust 后已无, 但本地可能仍有)
backend/
scripts/__pycache__/

# OS / editor noise
.DS_Store
**/.DS_Store
Thumbs.db
*.swp
*.swo
*.bak

# Logs
*.log

# Build outputs and signed release artifacts
build/
dist/
# `release/*` 而非 `release/` — 让 git 进入目录 + ignore 内容, 然后 ! negation
# 可以 re-include 个别文件 (git 文档: ignored 父目录里的 file 用 negation 不可达,
# 必须 selective glob)。
release/*
*.zip
*.exe
*.dmg
*.pkg
*.tar.gz
*.sig

# 例外: 公钥 PEM 跟 latest.json 必须进 git, 客户端 build-time include_str!
# 嵌公钥 + signature.rs 单测用真 latest.json/.sig 做 round-trip。
# 私钥永不 commit (CI 通过 RELEASE_PRIVATE_KEY_PEM secret 注入到 .release-signing/)。
!release/Codex-App-Transfer-release-public.pem
!release/latest.json
!release/latest.json.sig

# Generated NSIS installer at project root (named Codex-App-Transfer-Setup-<v>.exe)
Codex-App-Transfer-Setup-*.exe

# PyInstaller / signing runtime dirs
.release-signing/
.packaged-runtime-home/
.onefile-runtime-home/
.runtime-home/

# Scratch / working directories
.tmp/
.tmp-*/

# Claude Code harness state
.claude/

# Generated macOS icon assets (rebuilt by macos/prepare-icon.py)
macos/assets/app-icon.icns
macos/assets/app-icon.iconset/
macos/assets/app-icon-prepared.png

# === Local-only docs ===
# 整个 docs/ 不入仓库(2026-05-24 决定 — Linear 跟踪 followup,GitHub release notes
# 替代 docs/release-notes/,根目录 README + CHANGELOG + ACKNOWLEDGEMENTS + AGENTS +
# ONBOARDING + ARCHITECTURE_PROTOCOL_GUIDE 6 文件足够公开文档)。
# 维护者本地可在 docs/ 放任意调研 / 历史归档 / 上游 reference / agent review 报告 /
# wire dumps / 反馈分析 — 都不会进 remote。
docs/

# User-private feedback bundles (PDFs, configs, logs from real users — PII risk)
反馈/

# Feedback Worker secrets / 本地缓存
feedback-worker/.env
feedback-worker/.wrangler/
feedback-worker/node_modules/

# Rust / Tauri 2 工作区构建产物
/target/
**/target/
src-tauri/gen/
**/*.rs.bk

# IDE / editor noise
.vscode/
.idea/
*.iml

# Tauri auto-generated mobile icons(本仓不发移动端;`cargo tauri icon` 重生即可)
src-tauri/icons/android/
src-tauri/icons/ios/
