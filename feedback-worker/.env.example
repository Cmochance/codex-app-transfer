# 复制本文件为 .env 后填入真实值。
# .env 不会进 git(在根 .gitignore 里有规则)。
# 运行 ./setup-secrets.sh 把这些值推到 Cloudflare Worker secrets。

# Resend API Key,登 https://resend.com 注册后在 dashboard 创建。
# 免费版 100 封/天。
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# 接收新反馈通知的邮箱。
NOTIFY_EMAIL_TO=your-email@example.com

# 发件人。
# 没自有域名时直接用 Resend 默认沙箱发件人(只能发到 Resend 账号注册邮箱):
#   onboarding@resend.dev
# 有自有域名(在 Resend 验证过)时可以用:
#   "Codex App Transfer <feedback@your-domain.com>"
NOTIFY_EMAIL_FROM=onboarding@resend.dev
